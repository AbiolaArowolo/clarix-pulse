# Pulse - Hub Environment Variables
# Copy this file to .env or .env.local and fill in your values.
# The hub loads .env first, then .env.local (which overrides .env).
# Both files are gitignored and must never be committed.

# Hub server
HUB_PORT=3001

# PostgreSQL is now required for the hub control plane.
# Examples:
# PULSE_DATABASE_URL=postgres://pulse_user:strong_password@127.0.0.1:5432/clarix_pulse
# PULSE_DATABASE_URL=postgres://pulse_user:strong_password@db.example.com:5432/clarix_pulse?sslmode=require
PULSE_DATABASE_URL=postgres://pulse_user:REPLACE_ME@127.0.0.1:5432/clarix_pulse
# Optional: force SSL on/off if your connection string does not already express it.
# PULSE_DATABASE_SSL=true
# PULSE_DATABASE_SSL_REJECT_UNAUTHORIZED=false
# PULSE_DB_POOL_MAX=10
# PULSE_DB_IDLE_TIMEOUT_MS=30000
# Recommended behind HTTPS reverse proxies
PULSE_COOKIE_SECURE=true

# Hub-managed thumbnail file cache
PULSE_THUMBNAIL_DIR=/var/lib/clarix-pulse/thumbnails

# Legacy or fallback local self-enrollment
# New tenant registrations now get their own enrollment keys from the app.
PULSE_ENROLLMENT_KEY=REPLACE_ME

# Telegram alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerting (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@yourdomain.com
SMTP_TO=ops@yourdomain.com
# SMTP_TO and TELEGRAM_CHAT_ID can seed the first recipients.
# After deployment, the dashboard can store up to 3 emails, 3 Telegram chat IDs,
# and 3 phone numbers through the protected alert settings editor.

# Legacy bootstrap tokens - used to seed known nodes into Postgres on first start.
# The long-term path is generic enrollment, but existing nodes can still be carried
# in through the bootstrap env during migration.
# Leave legacy bootstrap disabled for clean generic installations unless you
# explicitly want the old sample catalog to appear.
# PULSE_ENABLE_LEGACY_BOOTSTRAP=true
# Format: node_id:token,node_id:token,...
AGENT_TOKENS=site-a-node-1:REPLACE_ME,site-a-node-2:REPLACE_ME,site-b-node-1:REPLACE_ME

# Optional ops metadata - not used by the hub runtime
VPS_HOST=
VPS_USER=
VPS_ROOT_PASSWORD=

# Optional DNS provider metadata - not used by the hub runtime
CF_EMAIL=
CF_PASSWORD=
