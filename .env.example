# Pulse - Hub Environment Variables
# Copy this file to .env or .env.local and fill in your values.
# The hub loads .env first, then .env.local (which overrides .env).
# Both files are gitignored and must never be committed.

# Hub server
HUB_PORT=3001

# Telegram alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerting (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@yourdomain.com
SMTP_TO=ops@yourdomain.com

# Agent authentication tokens - one per node
# Format: node_id:token,node_id:token,...
# Generate tokens with: openssl rand -hex 32
AGENT_TOKENS=site-a-node-1:REPLACE_ME,site-a-node-2:REPLACE_ME,site-b-node-1:REPLACE_ME

# Dashboard config editor
CONFIG_WRITE_KEY=

# Optional ops metadata - not used by the hub runtime
VPS_HOST=
VPS_USER=
VPS_ROOT_PASSWORD=

# Optional DNS provider metadata - not used by the hub runtime
CF_EMAIL=
CF_PASSWORD=
