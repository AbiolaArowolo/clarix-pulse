# Pulse — Hub Environment Variables
# Copy this file to .env or .env.local and fill in all values
# The hub loads .env first, then .env.local (which overrides .env)
# Both files are gitignored and must NEVER be committed

# Hub server
HUB_PORT=3001

# Telegram alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerting (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@clarixtech.com
SMTP_TO=support@clarixtech.com

# Agent authentication tokens — one per PC
# Format: agent_id:token,agent_id:token,...
# Generate tokens with: openssl rand -hex 32
AGENT_TOKENS=ny-main-pc:REPLACE_ME,ny-backup-pc:REPLACE_ME,nj-optimum-pc:REPLACE_ME,digicel-pc:REPLACE_ME

# Optional ops metadata — not used by the hub runtime
VPS_HOST=192.3.76.144
VPS_USER=root
VPS_ROOT_PASSWORD=

# Optional Cloudflare metadata — not used by the hub runtime
CF_EMAIL=Abayo83@gmail.com
CF_PASSWORD=
