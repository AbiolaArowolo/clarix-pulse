# Clarix Pulse recovery template
# Keep this file in Git as a checklist/template only.
# Do NOT replace the placeholders in Git with live production secrets.
# Put the real values in a private vault or in a local .env.local file when restoring.

HUB_PORT=3001
PULSE_DATABASE_URL=postgres://pulse_user:REPLACE_ME@127.0.0.1:5432/clarix_pulse
PULSE_COOKIE_SECURE=true
PULSE_ADMIN_EMAILS=REPLACE_ME
PULSE_ACCESS_KEY_TTL_DAYS=365
PULSE_PASSWORD_RESET_TTL_MINUTES=60
PULSE_THUMBNAIL_DIR=/var/lib/clarix-pulse/thumbnails
PULSE_DOWNLOAD_BUNDLE_PATH=
PULSE_DOWNLOAD_BUNDLE_NAME=clarix-pulse-v1.9.zip
PULSE_DOWNLOAD_SIGNING_SECRET=REPLACE_ME
PULSE_DOWNLOAD_LINK_TTL_MINUTES=1440
PULSE_ENROLLMENT_KEY=REPLACE_ME

SMTP_HOST=REPLACE_ME
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
SMTP_FROM_NAME=Clarix Pulse
SMTP_FROM=alerts@example.com
SMTP_TO=ops@example.com

TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=
AGENT_TOKENS=

VPS_HOST=REPLACE_ME
VPS_USER=REPLACE_ME
VPS_ROOT_PASSWORD=REPLACE_ME

CF_EMAIL=
CF_PASSWORD=
